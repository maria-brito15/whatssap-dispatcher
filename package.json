{
  "name": "whatssap-dispatcher",
  "version": "2.0.0",
  "description": "Sistema de disparo de mensagens WhatsApp com campanhas e fluxos automáticos",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "worker:all": "concurrently --names \"SCHED,SEND,RECON\" \"tsx src/workers/scheduler/scheduler.worker.ts\" \"tsx src/workers/sender/send-message.worker.ts\" \"tsx src/workers/reconciliation/reconciliation.worker.ts\"",
    "worker:scheduler": "tsx src/workers/scheduler/scheduler.worker.ts",
    "worker:sender": "tsx src/workers/sender/send-message.worker.ts",
    "worker:reconciliation": "tsx src/workers/reconciliation/reconciliation.worker.ts",
    "dev:all": "concurrently --names \"NEXT,SCHED,SEND,RECON\" \"npm run dev\" \"npm run worker:scheduler\" \"npm run worker:sender\" \"npm run worker:reconciliation\"",
    "seed": "tsx prisma/seed.ts",
    "clean": "rm -rf .next node_modules"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@wppconnect-team/wppconnect": "^1.41.3",
    "bullmq": "^5.78.1",
    "dotenv": "^16.6.1",
    "ioredis": "^5.11.1",
    "next": "15.2.0",
    "pg": "^8.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "redis": "^5.12.1",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.21",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "concurrently": "^9.2.1",
    "csv-parse": "^5.6.0",
    "eslint": "^9.21.0",
    "eslint-config-next": "15.2.0",
    "jest": "^29.7.0",
    "prisma": "^6.19.3",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
